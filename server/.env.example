# Railway environment variables

# Discord OAuth2 aplikacija
DISCORD_CLIENT_ID=tvoj_client_id
DISCORD_CLIENT_SECRET=tvoj_client_secret

# Discord server (Guild) i potrebna rola
DISCORD_GUILD_ID=tvoj_guild_id
DISCORD_REQUIRED_ROLE_ID=tvoj_role_id
DISCORD_UPLOAD_ROLE_IDS=tvoj_admin_role_id

# Discord bot token za admin dohvat rola
DISCORD_BOT_TOKEN=tvoj_bot_token

# Kanal za obavijesti o uspješno uploadanim/ažuriranim modovima
DISCORD_MOD_CHANNEL_ID=1487478328007987471

# Tajni kljuc za potpisivanje sesija (dugi random string)
JWT_SECRET=promijeni_me_u_dugi_random_string

# Javni URL Railway app servicea, bez kose crte na kraju
PUBLIC_URL=https://tvoj-railway-url.up.railway.app

# Railway MySQL variable reference na app serviceu
MYSQL_URL=${{MySQL.MYSQL_URL}}
